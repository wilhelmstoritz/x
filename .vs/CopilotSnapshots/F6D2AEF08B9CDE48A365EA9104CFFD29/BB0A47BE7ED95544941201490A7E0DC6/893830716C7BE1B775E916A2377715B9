@model weather_project.Models.weather_index_view_model

@{
    ViewData["Title"] = "weather";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">weather api project</h1>
        <p class="text-muted mb-0">nested json, dto modely, httpclient a async await</p>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-9">
                <label class="form-label" for="city_name">city name</label>
                <input id="city_name" name="city_name" value="@Model.city_name" class="form-control" />
            </div>
            <div class="col-md-3 d-grid gap-2">
                <button type="submit" class="btn btn-primary">nacist</button>
                <a asp-action="Index" class="btn btn-outline-secondary">default</a>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.error_message))
{
    <div class="alert alert-danger">@Model.error_message</div>
}
else if (Model.weather != null && Model.weather.current_condition.Count > 0 && Model.weather.nearest_area.Count > 0)
{
    var l_current = Model.weather.current_condition[0];
    var l_area = Model.weather.nearest_area[0];

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h4">@l_area.areaName.FirstOrDefault()?.value, @l_area.country.FirstOrDefault()?.value</h2>
            <p class="text-muted">@l_area.region.FirstOrDefault()?.value</p>
            <div class="row g-3">
                <div class="col-md-3"><div class="border rounded p-3">teplota: <strong>@l_current.temp_C °C</strong></div></div>
                <div class="col-md-3"><div class="border rounded p-3">pocitova teplota: <strong>@l_current.FeelsLikeC °C</strong></div></div>
                <div class="col-md-3"><div class="border rounded p-3">vitr: <strong>@l_current.windspeedKmph km/h</strong></div></div>
                <div class="col-md-3"><div class="border rounded p-3">vlhkost: <strong>@l_current.humidity %</strong></div></div>
                <div class="col-12"><div class="border rounded p-3">stav: <strong>@l_current.weatherDesc</strong></div></div>
            </div>
        </div>
    </div>
}
