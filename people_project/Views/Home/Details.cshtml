@model people_project.Models.person_item

@{
	ViewData["Title"] = "detail";
}

<div class="row justify-content-center">
	<div class="col-lg-8">
		<div class="card shadow-sm">
			<div class="card-body">
				<h1 class="h3 mb-3">detail osoby</h1>
				<dl class="row mb-0">
					<dt class="col-sm-4">jmeno</dt>
					<dd class="col-sm-8">@Model.jmeno</dd>
					<dt class="col-sm-4">prijmeni</dt>
					<dd class="col-sm-8">@Model.prijmeni</dd>
					<dt class="col-sm-4">datum narozeni</dt>
					<dd class="col-sm-8">@Model.datum_narozeni.ToString("dd.MM.yyyy")</dd>
					<dt class="col-sm-4">vyska</dt>
					<dd class="col-sm-8">@Model.vyska_cm cm</dd>
					<dt class="col-sm-4">vaha</dt>
					<dd class="col-sm-8">@Model.vaha_kg kg</dd>
					<dt class="col-sm-4">mesto</dt>
					<dd class="col-sm-8">@Model.mesto</dd>
				</dl>
				<div class="mt-3 d-flex gap-2">
					<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.id">upravit</a>
					<a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.id">smazat</a>
					<a class="btn btn-secondary" asp-action="Index">zpet</a>
				</div>
			</div>
		</div>
	</div>
</div>
