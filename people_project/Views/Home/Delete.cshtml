@model people_project.Models.person_item

@{
	ViewData["Title"] = "delete";
}

<div class="row justify-content-center">
	<div class="col-lg-8">
		<div class="card border-danger shadow-sm">
			<div class="card-body">
				<h1 class="h3 mb-3 text-danger">smazat osobu</h1>
				<p>opravdu chcete smazat tuto osobu?</p>
				<dl class="row mb-0">
					<dt class="col-sm-4">jmeno</dt>
					<dd class="col-sm-8">@Model.jmeno</dd>
					<dt class="col-sm-4">prijmeni</dt>
					<dd class="col-sm-8">@Model.prijmeni</dd>
					<dt class="col-sm-4">mesto</dt>
					<dd class="col-sm-8">@Model.mesto</dd>
				</dl>
				<form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
					<input asp-for="id" type="hidden" />
					<button type="submit" class="btn btn-danger">ano, smazat</button>
					<a asp-action="Details" asp-route-id="@Model.id" class="btn btn-secondary">zpet</a>
				</form>
			</div>
		</div>
	</div>
</div>
