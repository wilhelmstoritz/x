@model people_project.Models.people_statistics_view_model

@{
	ViewData["Title"] = "statistics";
}

<div class="row justify-content-center">
	<div class="col-lg-8">
		<div class="card shadow-sm">
			<div class="card-body">
				<h1 class="h3 mb-3">statistiky</h1>
				<div class="row g-3">
					<div class="col-md-6"><div class="border rounded p-3">pocet lidi: <strong>@Model.pocet_lidi</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">prumerny vek: <strong>@Model.prumerny_vek</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">prumerna vyska: <strong>@Model.prumerna_vyska_cm cm</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">maximalni vyska: <strong>@Model.maximalni_vyska_cm cm</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">prumerna vaha: <strong>@Model.prumerna_vaha_kg kg</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">maximalni vaha: <strong>@Model.maximalni_vaha_kg kg</strong></div></div>
				</div>
				<div class="mt-3">
					<a asp-action="Index" class="btn btn-secondary">zpet</a>
				</div>
			</div>
		</div>
	</div>
</div>
