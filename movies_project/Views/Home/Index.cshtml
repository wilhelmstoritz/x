@model movies_project.Models.movies_index_view_model

@{
    ViewData["Title"] = "movies";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">movies api project</h1>
        <p class="text-muted mb-0">httpclient, async await, seznam, detail a statistiky</p>
    </div>
    <a asp-action="Statistics" class="btn btn-outline-secondary">statistiky</a>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-9">
                <label asp-for="search_title" class="form-label"></label>
                <input asp-for="search_title" class="form-control" />
            </div>
            <div class="col-md-3 d-grid gap-2">
                <button type="submit" class="btn btn-primary">vyhledat</button>
                <a asp-action="Index" class="btn btn-outline-secondary">reset</a>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var l_movie in Model.movies)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">@l_movie.title</h2>
                    <p class="text-muted mb-2">@l_movie.director</p>
                    <p class="small flex-grow-1">@l_movie.description</p>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="badge bg-primary">@l_movie.rt_score</span>
                        <a asp-action="Details" asp-route-id="@l_movie.id" class="btn btn-sm btn-outline-primary">detail</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
