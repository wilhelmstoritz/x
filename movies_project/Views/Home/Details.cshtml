@model movies_project.Models.movie_item

@{
	ViewData["Title"] = "detail";
}

<div class="row justify-content-center">
	<div class="col-lg-8">
		<div class="card shadow-sm">
			<div class="card-body">
				<h1 class="h3 mb-3">@Model.title</h1>
				<dl class="row mb-0">
					<dt class="col-sm-4">original title</dt>
					<dd class="col-sm-8">@Model.original_title</dd>
					<dt class="col-sm-4">romanised title</dt>
					<dd class="col-sm-8">@Model.original_title_romanised</dd>
					<dt class="col-sm-4">director</dt>
					<dd class="col-sm-8">@Model.director</dd>
					<dt class="col-sm-4">producer</dt>
					<dd class="col-sm-8">@Model.producer</dd>
					<dt class="col-sm-4">release date</dt>
					<dd class="col-sm-8">@Model.release_date</dd>
					<dt class="col-sm-4">running time</dt>
					<dd class="col-sm-8">@Model.running_time min</dd>
					<dt class="col-sm-4">rating score</dt>
					<dd class="col-sm-8">@Model.rt_score</dd>
				</dl>
				<p class="mt-3">@Model.description</p>
				<a asp-action="Index" class="btn btn-secondary">zpet</a>
			</div>
		</div>
	</div>
</div>
