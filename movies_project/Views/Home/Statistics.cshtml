@model movies_project.Models.movie_statistics_view_model

@{
	ViewData["Title"] = "statistics";
}

<div class="row justify-content-center">
	<div class="col-lg-8">
		<div class="card shadow-sm">
			<div class="card-body">
				<h1 class="h3 mb-3">movie statistics</h1>
				<div class="row g-3">
					<div class="col-md-6"><div class="border rounded p-3">pocet filmu: <strong>@Model.movies_count</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">prumerny score: <strong>@Model.average_score</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">max score: <strong>@Model.max_score</strong></div></div>
					<div class="col-md-6"><div class="border rounded p-3">min score: <strong>@Model.min_score</strong></div></div>
					<div class="col-12"><div class="border rounded p-3">nejlepsi film: <strong>@Model.top_movie_title</strong></div></div>
				</div>
				<div class="mt-3">
					<a asp-action="Index" class="btn btn-secondary">zpet</a>
				</div>
			</div>
		</div>
	</div>
</div>
